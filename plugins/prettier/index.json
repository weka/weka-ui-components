{
  "semi": false,
  "jsxSingleQuote": true,
  "singleQuote": true,
  "bracketSpacing": true,
  "trailingComma": "all",
  "bracketSameLine": false,
  "printWidth": 100,
  "singleAttributePerLine": true,
  "overrides": [
    {
      "files": ["*.js", "*.jsx", "*.ts", "*.tsx", "**/*.test.*"],
      "options": {
        "printWidth": 80
      }
    },
    {
      "files": ["*.json"],
      "options": {
        "printWidth": 1
      }
    }
  ]
}
