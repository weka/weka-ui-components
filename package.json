{
  "name": "@weka/weka-ui-components",
  "repository": {
    "type": "git",
    "url": "https://github.com/weka/weka-ui-components.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "version": "4.8.0",
  "module": "lib/main.ts",
  "types": "lib/main.ts",
  "typesVersions": {
    "*": {
      "v2": [
        "./dist/v2/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -c .storybook",
    "predeploy-storybook": "yarn run build-storybook",
    "deploy-storybook": "gh-pages -d storybook-static",
    "typecheck": "tsc",
    "lintcheck": "eslint .",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "release:patch": "npm version patch && git push -u origin HEAD && git push --tags",
    "release:minor": "npm version minor && git push -u origin HEAD && git push --tags",
    "release:major": "npm version major && git push -u origin HEAD && git push --tags",
    "release:beta": "npm version prerelease --preid beta && git push -u origin HEAD && git push --tags"
  },
  "files": [
    "lib",
    "plugins",
    "dist"
  ],
  "exports": {
    ".": "./lib/main.ts",
    "./v2": {
      "types": "./dist/v2/index.d.ts",
      "development": "./lib/v2/index.ts",
      "default": "./dist/v2/index.js"
    },
    "./plugins": {
      "types": "./plugins/index.d.ts",
      "default": "./plugins/index.js"
    },
    "./eslint": "./plugins/eslint/index.js",
    "./prettier-config": "./plugins/prettier/index.json",
    "./typescript-config": "./plugins/typescript/tsconfig.base.json",
    "./lib/*": "./lib/*"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "ace-builds": "^1.43.6",
    "check-password-strength": "^2.0.7",
    "clsx": "^2.1.1",
    "copy-to-clipboard": "^3.3.3",
    "luxon": "^3.7.2",
    "react-ace": "^12.0.0",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-select": "^5.10.2",
    "react-toastify": "^9.1.3",
    "react-use": "^17.6.0",
    "simplebar-react": "^3.3.2"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^5.11.1",
    "luxon": "^3.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.6.2 || ^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@chromatic-com/storybook": "^2.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/compat": "^1.2.9",
    "@eslint/js": "^9.0.0",
    "@mui/material": "^5.11.1",
    "@storybook/addon-actions": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.3",
    "@storybook/preset-scss": "^1.0.3",
    "@storybook/react": "^8.6.14",
    "@storybook/react-webpack5": "^8.6.14",
    "@storybook/test": "^8.6.15",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^27",
    "@types/luxon": "^3.7.1",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@weka/eslint-config": "https://github.com/weka/eslint-config#1.1.0",
    "babel-loader": "^9.1.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^5.0.0",
    "globals": "^14.0.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^27.4.0",
    "prettier": "^2.8.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "sass": "^1.98.0",
    "sass-loader": "^14.2.1",
    "storybook": "^8.6.17",
    "storybook-solidjs": "^1.0.0-beta.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "url-loader": "^4.1.1",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.2",
    "vitest": "^4.1.0"
  },
  "resolutions": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "brace-expansion": "2.0.2",
    "globals": "^14.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "packageManager": "yarn@4.6.0"
}
